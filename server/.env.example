# Copy to .env and edit
PORT=3001

# Admin credentials
# IMPORTANT: Provide either ADMIN_PASSWORD_PLAIN (for initial setup) and leave ADMIN_PASSWORD_HASH empty,
# or provide ADMIN_PASSWORD_HASH directly.
ADMIN_USERNAME=admin

# Option A (one-time): provide plain password; server will hash on startup
ADMIN_PASSWORD_PLAIN=ChangeMe!123

# Option B: provide bcrypt hash directly (recommended for production)
# ADMIN_PASSWORD_HASH=$2a$...

# JWT secret
JWT_SECRET=change-me-in-prod

